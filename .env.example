# Secure Academic Management System (SAMS)
# Copy this file to .env and update values.

# --------------------
# Server / Backend
# --------------------
NODE_ENV=production
PORT=5000

# Prisma / Database
DATABASE_URL=postgresql://sams_user:sams_password_change_me@postgres:5432/sams_db
DB_USER=sams_user
DB_PASSWORD=sams_password_change_me
DB_HOST=postgres
DB_PORT=5432
DB_NAME=sams_db

# JWT
# Must be at least 32 characters
JWT_SECRET=change_me_to_a_long_random_secret_value_at_least_32_chars
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=change_me_to_a_long_random_refresh_secret_value_at_least_32_chars

JWT_EXPIRY=15m
JWT_ACCESS_EXPIRY=
JWT_REFRESH_EXPIRY=7d

# CORS - provide the exact origin of your frontend in production
# Example: https://yourdomain.com
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# Password hashing + login protection
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME=30m

# Rate limiting (API)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Redis (optional)
REDIS_HOST=redis
REDIS_PORT=6379

# SMTP (optional - for notifications/password reset)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --------------------
# Client / Frontend
# --------------------
# Used by Vite at build time.
# When served behind nginx at same origin, prefer relative path.
VITE_API_URL=/api/v1

